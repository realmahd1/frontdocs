# BotFather token — server-side only
TELEGRAM_BOT_TOKEN=123456789:replace_me

# A random secret sent by Telegram in the webhook request header
TELEGRAM_WEBHOOK_SECRET=replace_with_a_long_random_value

# Channel numeric ID, for example -1001234567890
TELEGRAM_ALLOWED_CHANNEL_ID=-1001234567890

# Public HTTPS address of this Next.js application
NEXT_PUBLIC_SITE_URL=https://blog.example.com
# Optional full override:
# TELEGRAM_WEBHOOK_URL=https://blog.example.com/api/telegram/webhook

BLOG_DEFAULT_AUTHOR=M.Mahdi Saeidi

# Optional filesystem locations, relative to the project root or absolute
# BLOG_POSTS_DIR=content/posts
# TELEGRAM_FRAGMENTS_DIR=content/telegram
# BLOG_GENERATED_DIR=storage/generated
